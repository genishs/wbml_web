var SspAdContentCallerForPC = $Class({
    $init: function(beyondAnalyticsUrl,baUserKey,blogNo,logNo,gbTrackingCode,adBucket) {
        this.beyondAnalyticsUrl = beyondAnalyticsUrl;
        this.baUserKey = baUserKey;
        this.blogNo = blogNo;
        this.logNo = logNo;
        this.gbTrackingCode = gbTrackingCode;
        this.adBucket = adBucket || '';

        this._adContentLocationCode = "";
        this.adDivId = {
            middle1: 'ssp-adcontent-1', // ліёл¬ё мӨ‘к°„ 30% м§Җм җ кҙ‘кі  div id
            middle2: 'ssp-adcontent-2', // ліёл¬ё мӨ‘к°„ 60% м§Җм җ кҙ‘кі  div id
            bottom: 'ssp-adcontent', // н•ҳлӢЁ кҙ‘кі  div id
        };
    },

    renderAdContent: function (tagData, adContentLocation) {
        // ліёл¬ёкҙ‘кі  мң„м№ҳ м„ нғқ: мӨ‘к°„
        if (adContentLocation === "1") {
            this._adContentLocationCode = "middle";
            var adSlotInfo = this._appendMiddleAdvertiseDiv30(tagData, this.adDivId.middle1, gAdContentUnitIdForPC, 1);
            if (adSlotInfo) {
                this._renderAdForDuplication([adSlotInfo]);
            }
        }

        // ліёл¬ёкҙ‘кі  мң„м№ҳ м„ нғқ: н•ҳлӢЁ
        else if (adContentLocation === "2") {
            this._adContentLocationCode = "bottom";
            this._appendBottomAdvertiseDiv(tagData, this.adDivId.bottom, gAdContentUnitIdForPC);
        }

        // ліёл¬ёкҙ‘кі  мң„м№ҳ м„ нғқ: лӘЁл‘җ(мӨ‘к°„/н•ҳлӢЁ)
        else {
            this._adContentLocationCode = "both";
            this._appendBottomAdvertiseDiv(tagData, this.adDivId.bottom, gAdContentUnitIdForPC);

            var contentEl = $$.getSingle(".se-viewer");
            if (typeof contentEl != "undefined" && contentEl.offsetHeight > 2700) { // ліёл¬ё кёёмқҙ 2700px мқҙмғҒ
                var adSlotList = [];
                // ліёл¬ё 30% м§Җм җм—җ кҙ‘кі  л…ём¶ң
                var adSlotInfo1 = this._appendMiddleAdvertiseDiv30(tagData, this.adDivId.middle1, gAdContentDaUnitIdForPc, 2);
                if (adSlotInfo1) {
                    adSlotList.push(adSlotInfo1);
                }

                // ліёл¬ё 60% м§Җм җм—җ кҙ‘кі  л…ём¶ң
                var adSlotInfo2 = this._appendMiddleAdvertiseDiv60(tagData, this.adDivId.middle2, gAdContentDaUnitIdForPc2);
                if (adSlotInfo2) {
                    adSlotList.push(adSlotInfo2);
                }

                this._renderAdForDuplication(adSlotList);
            }
        }

        // к°Ғк°Ғ elementк°Җ мһҲмқ„кІҪмҡ°л§Ң eventлҘј кІҖ
        var elMiddle1 = document.getElementById(this.adDivId.middle1);
        if (elMiddle1 != null && typeof gAdContentDaUnitIdForPc !== 'undefined' && gAdContentDaUnitIdForPc !== "") {
            new ContentAdExposureEvent(elMiddle1, this.beyondAnalyticsUrl, this.baUserKey, this.blogNo, this.logNo, this.gbTrackingCode ,gAdContentDaUnitIdForPc);
        }

        var elMiddle2 = document.getElementById(this.adDivId.middle2);
        if (elMiddle2 != null && typeof gAdContentDaUnitIdForPc2 !== 'undefined' && gAdContentDaUnitIdForPc2 !== "") {
            new ContentAdExposureEvent(elMiddle2, this.beyondAnalyticsUrl, this.baUserKey, this.blogNo, this.logNo, this.gbTrackingCode ,gAdContentDaUnitIdForPc2);
        }

        var elBottom = document.getElementById(this.adDivId.bottom);
        if (elBottom != null && typeof gAdContentUnitIdForPC !== 'undefined' && gAdContentUnitIdForPC !== "") {
            new ContentAdExposureEvent(elBottom, this.beyondAnalyticsUrl, this.baUserKey, this.blogNo, this.logNo, this.gbTrackingCode ,gAdContentUnitIdForPC);
        }
    },

    // ліёл¬ё 30% м§Җм җм—җ кҙ‘кі  л…ём¶ң
    _appendMiddleAdvertiseDiv30: function (tagData, adDivId, adDaUnit, componentLengthLimit) {
        // SE м»ҙнҸ¬л„ҢнҠё мЎ°нҡҢ
        var seComponents = Array.prototype.slice.call(
            document.querySelectorAll("#postListBody ._post_wrap:first-of-type .se-main-container .se-component, #postListBody ._post_wrap:first-of-type .__se_component_area .se_component")
        );

        // SE м»ҙнҸ¬л„ҢнҠё мҲҳк°Җ limit(мӨ‘лӢЁ: 1/ мӨ‘н•ҳлӢЁ лӘЁл‘җ: 2) ліҙлӢӨ м Ғмңјл©ҙ return
        if (componentLengthLimit && (seComponents.length < componentLengthLimit)) {
            return false;
        }

        // SE м»ҙнҸ¬л„ҢнҠёк°Җ 1к°ңмқҙл©ҙ н•ҙлӢ№ м»ҙнҸ¬л„ҢнҠё м•„лһҳм—җ л…ём¶ң
        if (seComponents.length === 1) {
            seComponents[0].parentNode.after(this._makeAdDiv(adDivId));
            return false;
        }

        // 30% м§Җм җм—җ кҙ‘кі  div л…ём¶ң
        this._appendMiddleAdvertiseByPosition(adDivId, seComponents, 30);
        return this._defineSlot(tagData, adDivId, adDaUnit, this._adContentLocationCode);
    },

    // ліёл¬ё 60% м§Җм җм—җ кҙ‘кі  л…ём¶ң
    _appendMiddleAdvertiseDiv60: function (tagData, adDivId, adDaUnit) {
        // SE м»ҙнҸ¬л„ҢнҠё мЎ°нҡҢ
        var seComponents = Array.prototype.slice.call(
            document.querySelectorAll("#postListBody ._post_wrap:first-of-type .se-main-container .se-component, #postListBody ._post_wrap:first-of-type .__se_component_area .se_component")
        );

        // SE м»ҙнҸ¬л„ҢнҠё мҲҳк°Җ 2к°ң ліҙлӢӨ м Ғмңјл©ҙ return
        if (seComponents.length < 2) {
            return false;
        }

        // 60% м§Җм җм—җ кҙ‘кі  div л…ём¶ң
        var validPosition = this._appendMiddleAdvertiseByPosition(adDivId, seComponents, 60);
        if (!validPosition) {
            return false;
        }

        return this._defineSlot(tagData, adDivId, adDaUnit, this._adContentLocationCode);
    },

    // ліёл¬ё {percent}% м§Җм җм—җ кҙ‘кі  л…ём¶ң
    _appendMiddleAdvertiseByPosition: function (adDivId, seComponents, percent) {
        // м „мІҙ м»ҙнҸ¬л„ҢнҠё кёёмқҙ мЎ°нҡҢ
        var totalHeight = 0;
        seComponents.forEach(function (el) {
            totalHeight += el.offsetHeight;
        });

        // {percent}% м§Җм җм—җ кҙ‘кі  div л…ём¶ң
        var targetHeight = totalHeight * (percent / 100); // м „мІҙ SE м»ҙнҸ¬л„ҢнҠё лҶ’мқҙ мҙқн•©мқҳ {percent}%
        for (var i in seComponents) {
            var seComponent = seComponents[i];
            targetHeight -= this._targetOffset(seComponent); // SE м»ҙнҸ¬л„ҢнҠёмқҳ лҶ’мқҙл§ҢнҒј л№јкё°

            // {percent}% м§Җм җм—җ н•ҙлӢ№н•ҳлҠ” SE м»ҙнҸ¬л„ҢнҠё л°”лЎң мң„м—җ кҙ‘кі  л…ём¶ң
            // targetHeight < 0: м „мІҙ SE м»ҙнҸ¬л„ҢнҠё лҶ’мқҙ мҙқн•©мқҳ {percent}% м—җм„ң SE м»ҙнҸ¬л„ҢнҠёл“Өмқҳ лҶ’мқҙлҘј н•ҳлӮҳм”© ләҖкІҢ мқҢмҲҳк°Җ лҗҳлҠ” м§Җм җмқҙ {percent}% м§Җм җ
            if (targetHeight < 0 && i > 0) {
                // кҙ‘кі  мҳҒм—ӯ div л…ём¶ң
                if (seComponent.previousElementSibling && seComponent.previousElementSibling.classList.contains('ssp-adcontent')) {
                    return false;
                }
                seComponent.parentNode.insertBefore(this._makeAdDiv(adDivId), seComponent);
                return true;
            }
        }
    },

    // SE м»ҙнҸ¬л„ҢнҠё лҶ’мқҙ мЎ°нҡҢ
    _targetOffset: function (seComponent) {
        var offSetHeight = seComponent.offsetHeight;

        // lazy loading л“ұмңјлЎң мқён•ҙ heightмқҙ м—ҶлҠ” componentлҠ” кё°ліёк°’ 400мңјлЎң н•ңлӢӨ
        if (offSetHeight < 1) {
            return 400;
        }

        return offSetHeight;
    },

    // н•ҳлӢЁ кҙ‘кі  л…ём¶ң
    _appendBottomAdvertiseDiv: function (tagData, adDivId, adDaUnit) {
        var seComponents = Array.prototype.slice.call(
            document.querySelectorAll("#postListBody ._post_wrap:first-of-type .se-main-container .se-component, #postListBody ._post_wrap:first-of-type .__se_component_area .se_component")
        );
        if (seComponents.length === 0) {
            return;
        }

        var lastComponent = seComponents[seComponents.length - 1];
        if (lastComponent && lastComponent.parentNode) {
            lastComponent.parentNode.appendChild(this._makeAdDiv(adDivId));
        }

        this._renderAd(tagData, adDivId, adDaUnit, this._adContentLocationCode);
    },

    // кҙ‘кі  л ҢлҚ”л§Ғ лҢҖмғҒ Slot м •мқҳ
    _defineSlot: function (tagData, adDivId, adUnitId, adContentLocation) {
        var extraOption = this._makeExtraOptionParam(tagData, true, adContentLocation, adUnitId);

        return {
            adUnitId: adUnitId,
            adSlotElementId: adDivId,
            customParam: extraOption,
        };
    },

    // кҙ‘кі  л ҢлҚ”л§Ғ
    _renderAd: function (tagData, adDivId, adUnitId, adContentLocation) {
        var extraOption = this._makeExtraOptionParam(tagData, true, adContentLocation, adUnitId);

        window.gladsdk = window.gladsdk || { cmd: [] };
        window.gladsdk.cmd.push(function () {
            window.gladsdk.setGlobalConfig({
                enablePersistAd: true
            });
            window.gladsdk.defineAdSlot({
                adUnitId: adUnitId,
                adSlotElementId: adDivId,
                customParam: extraOption,
            });
            window.gladsdk.displayAd(adDivId);
        });
    },

    // кҙ‘кі  л ҢлҚ”л§Ғ(мӨ‘ліө кҙ‘кі  м ңм–ҙ)
    _renderAdForDuplication: function (adSlotInfoList) {
        if (!adSlotInfoList || adSlotInfoList.length === 0) {
            return;
        }
        var deduplicationId = 'sspAdContentPc';
        var maxDeduplicationCount = 2;

        window.gladsdk = window.gladsdk || { cmd: [] };
        window.gladsdk.cmd.push(function () {
            window.gladsdk.setGlobalConfig({
                enablePersistAd: true
            });
            var adSlotList = [];
            for (var i = 0; i < adSlotInfoList.length; i++) {
                var adSlot = window.gladsdk.defineAdSlot(adSlotInfoList[i]);
                adSlotList.push(adSlot);
            }
            window.gladsdk.setAdDeduplication(deduplicationId, maxDeduplicationCount);
            var adDedupManager = window.gladsdk.findAdDedupManager(deduplicationId);
            adDedupManager.displayAds(adSlotList);
        });
    },

    // кҙ‘кі  л ҢлҚ”л§Ғ мҳөм…ҳ мғқм„ұ
    _makeExtraOptionParam: function (tagData, adContentYN, adContentLocation, adUnitId) {
        for (var i in tagData) {
            if (tagData[i].logno == gnFirstLogNo) {
                this.tagNames = decodeURIComponent(tagData[i].tagName);
            }
        }

        var buckets = this._parseBucketForUnit(this.adBucket, adUnitId);
        var params = {
            blogId: gBlogId,
            pid: "" + gnFirstLogNo,
            gdid: "" + gdid,
            sessionId: gsSesseionId,
            publisherRequest: gsBlogOwnerYn,
            cnt: 1,
            pk: gsSearchKeyword,
            pt: this.tagNames,
            adContentYN: adContentYN,
            adLocation: adContentLocation,
            saInfo: gsSaInfo,
            blogGrade: 5
        };

        // bucketsк°Җ л№Ҳ л¬ёмһҗм—ҙмқҙ м•„лӢҢ кІҪмҡ°м—җл§Ң н•„л“ң м¶”к°Җ
        if (buckets !== '') {
            params.buckets = buckets;
        }

        return params;
    },

    // кҙ‘кі  л…ём¶ң мҳҒм—ӯ div мғқм„ұ
    _makeAdDiv: function (adDivId) {
        var advertiseWrapDiv = document.createElement('div');
        advertiseWrapDiv.className = 'ssp-adcontent align_center';

        var advertiseDiv = document.createElement('div');
        advertiseDiv.id = adDivId;
        advertiseDiv.className = 'ssp_adcontent_inner';

        advertiseWrapDiv.append(advertiseDiv);
        return advertiseWrapDiv;
    },

    /**
     * adBucketмқ„ нҢҢмӢұн•ҳм—¬ нҠ№м • unit IDм—җ н•ҙлӢ№н•ҳлҠ” bucket м •ліҙлҘј л°ҳнҷҳ
     * @param {string} adBucket - JSON л¬ёмһҗм—ҙ нҳ•нғңмқҳ adBucket (мҳҲ: '{"pc_blog_body":"bucket1", "pc_blog_bottom":"bucket2"}')
     * @param {string} unitId - кҙ‘кі  unit ID (мҳҲ: 'pc_blog_bottom', 'pc_blog_body')
     * @returns {string} - н•ҙлӢ№ unitмқҳ bucket м •ліҙ лҳҗлҠ” л№Ҳ л¬ёмһҗм—ҙ
     */
    _parseBucketForUnit: function (adBucket, unitId) {
        if (!adBucket || !unitId) {
            return '';
        }

        try {
            // JSON нҢҢмӢұ мӢңлҸ„
            var bucketObj = JSON.parse(adBucket);
            return bucketObj[unitId] || '';
        } catch (e) {
            // JSONмқҙ м•„лӢҲл©ҙ мӣҗліё л¬ёмһҗм—ҙ л°ҳнҷҳ (н•ҳмң„ нҳёнҷҳм„ұ)
            return adBucket;
        }
    }
});
